# =============================================================================
# langchain4j-agent-demo 生产环境配置
# =============================================================================
# 使用前请复制本文件为 .env 并修改所有标记为 CHANGE_ME 的值
# 命令: cp .env.production .env && vim .env
# =============================================================================

# ========================== 一、基础配置 ==========================

# 部署环境标识
SPRING_PROFILES_ACTIVE=production

# ========================== 二、AI 模型配置 ==========================

# 阿里云通义千问 API Key（必填）
# 申请地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=CHANGE_ME
# 模型服务地址（默认阿里云，也可切换为自建 OpenAI 兼容服务）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 使用的模型名称（qwen-max / qwen-plus / qwen-turbo）
DASHSCOPE_MODEL=qwen-max

# ========================== 三、数据库配置 ==========================

# --- 方案 A：H2 嵌入式数据库（轻量部署，默认） ---
SPRING_DATASOURCE_URL=jdbc:h2:file:/app/data/ai-agent-db;DB_CLOSE_ON_EXIT=FALSE
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# --- 方案 B：MySQL 数据库（生产推荐） ---
# 取消以下注释并注释方案 A
# SPRING_DATASOURCE_URL=jdbc:mysql://mysql-host:3306/agent_db?useSSL=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8mb4
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
# SPRING_DATASOURCE_USERNAME=CHANGE_ME
# SPRING_DATASOURCE_PASSWORD=CHANGE_ME

# 连接池配置（已优化，一般无需修改）
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=20
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=5
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=600000
SPRING_DATASOURCE_HIKARI_MAX_LIFETIME=1800000

# ========================== 四、Redis 配置 ==========================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_secure_password
REDIS_TIMEOUT=5000

# Lettuce 连接池（已优化）
SPRING_DATA_REDIS_LETTUCE_POOL_MAX_ACTIVE=20
SPRING_DATA_REDIS_LETTUCE_POOL_MAX_IDLE=10
SPRING_DATA_REDIS_LETTUCE_POOL_MIN_IDLE=5

# ========================== 五、Milvus 向量数据库配置 ==========================

MILVUS_ENABLED=true
MILVUS_HOST=milvus
MILVUS_PORT=19530
# Milvus 内部 MinIO 存储凭证（生产环境务必修改）
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key

# ========================== 六、安全配置 ==========================

# JWT 密钥（必填，至少 32 字符，建议 64 字符随机字符串）
JWT_SECRET=CHANGE_ME_at_least_32_chars_random_secret_key_for_jwt_signing
# JWT 过期时间（秒，默认 24 小时）
JWT_EXPIRATION=86400

# ========================== 七、API 限流配置 ==========================

RATE_LIMIT_ENABLED=true
# 每分钟请求数上限
RATE_LIMIT_RPM=100
# 突发容量上限
RATE_LIMIT_BURST=150

# ========================== 八、AI 监管配置 ==========================

# 单次请求最大 Token 数
AI_SUPERVISOR_MAX_TOKENS_PER_REQUEST=10000
# 每小时最大 Token 消耗
AI_SUPERVISOR_MAX_TOKENS_PER_HOUR=100000
# 每天最大 Token 消耗
AI_SUPERVISOR_MAX_TOKENS_PER_DAY=1000000
# 最大并发请求数
AI_SUPERVISOR_MAX_CONCURRENT_REQUESTS=10

# ========================== 九、对话记忆配置 ==========================

# 单会话最大消息数
CHAT_MEMORY_MAX_MESSAGES=50
# ChatMemoryProvider 最大消息数
CHAT_MEMORY_PROVIDER_MAX_MESSAGES=30

# ========================== 十、JVM 与日志配置 ==========================

# JVM 参数（容器内自动感知内存，按 75% 分配堆）
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -Djava.security.egd=file:/dev/./urandom

# 日志级别（生产建议 INFO，排查问题时可临时改为 DEBUG）
LOGGING_LEVEL_COM_YOURCOMPANY=INFO
LOGGING_LEVEL_DEV_LANGCHAIN4J=INFO
LOGGING_FILE_NAME=/app/logs/application.log

# 是否记录 LLM 请求/响应详情（生产建议关闭，含敏感信息）
LOG_REQUESTS=false
LOG_RESPONSES=false

# ========================== 十一、Grafana 监控配置 ==========================

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ========================== 十二、Nginx/SSL 配置（如需 HTTPS） ==========================

# 域名
DOMAIN=CHANGE_ME_your-domain.com
# SSL 证书路径（放在 nginx/ssl/ 目录下）
# SSL_CERT_FILE=/etc/nginx/ssl/fullchain.pem
# SSL_KEY_FILE=/etc/nginx/ssl/privkey.pem
